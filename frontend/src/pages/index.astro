---
import '../styles/theme.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Odisha Wiki - Launching Soon</title>

		<!-- SEO Meta Tags -->
		<meta name="description" content="Odisha Wiki - Everything about Odisha, in one place. Official launch timer." />
		<meta name="keywords" content="Odisha, Wiki, Odisha Wiki, Odia, History, Culture, Tourism, Odisha Portal" />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Oriya:wght@400;500;600;700&family=Teko:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="container">
			<header class="header">
				<div class="header-top">
					<div class="lang-switcher">
						<button id="btn-od" class="lang-btn">ଓଡ଼ିଆ</button>
						<button id="btn-en" class="lang-btn">English</button>
					</div>
				</div>
				<p id="tagline" class="top-tagline"></p>
			</header>

			<main class="main-content">
				<h1 id="brand-title" class="logo">odisha<span>.wiki</span></h1>
				<div class="divider"></div>
				<p id="subtitle" class="subtitle"></p>

				<div id="status-label" class="status-label"></div>

				<div class="timer-container" aria-live="polite">
					<div class="timer-segment">
						<span id="days" class="timer-number"></span>
						<span id="days-label" class="timer-label"></span>
					</div>
					<div class="timer-colon">:</div>
					<div class="timer-segment">
						<span id="hours" class="timer-number"></span>
						<span id="hours-label" class="timer-label"></span>
					</div>
					<div class="timer-colon">:</div>
					<div class="timer-segment">
						<span id="minutes" class="timer-number"></span>
						<span id="minutes-label" class="timer-label"></span>
					</div>
					<div class="timer-colon">:</div>
					<div class="timer-segment">
						<span id="seconds" class="timer-number"></span>
						<span id="seconds-label" class="timer-label"></span>
					</div>
				</div>
			</main>

			<footer class="footer">
				<p id="footer-text" class="footer-text"></p>
				<div class="footer-divider"></div>
			</footer>
		</div>

		<style>
			* {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			body {
				background-color: var(--bg);
				background-image:
					radial-gradient(circle at center, rgba(5, 5, 5, 0.1) 0%, rgba(5, 5, 5, 0.85) 90%),
					linear-gradient(to right, rgba(5, 5, 5, 0.9) 0%, rgba(5, 5, 5, 0.4) 60%, rgba(5, 5, 5, 0.9) 100%),
					url('/bg-image.png');
				background-size: cover;
				background-position: right center;
				background-repeat: no-repeat;
				background-attachment: fixed;
				color: var(--white);
				font-family: var(--font-sans);
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				overflow-x: hidden;
			}

			.container {
				width: 100%;
				max-width: 1200px;
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				align-items: center;
				padding: 2rem 2rem 3rem 2rem;
				z-index: 10;
			}

			.header {
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				margin-top: 1rem;
			}

			.header-top {
				display: flex;
				justify-content: flex-end;
				width: 100%;
				max-width: 1200px;
				margin-bottom: 2rem;
			}

			.lang-switcher {
				display: flex;
				background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.02) 100%);
				border: 1px solid rgba(255, 255, 255, 0.12);
				border-radius: 30px;
				padding: 4px;
				backdrop-filter: blur(16px);
				-webkit-backdrop-filter: blur(16px);
				box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
			}

			.lang-btn {
				background: transparent;
				border: 1px solid transparent;
				color: var(--text-muted);
				padding: 0.5rem 1.2rem;
				font-size: 0.85rem;
				font-weight: 600;
				border-radius: 25px;
				cursor: pointer;
				transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
				font-family: var(--font-sans), var(--font-oriya);
			}

			.lang-btn.active {
				background: rgba(193, 18, 31, 0.75);
				color: var(--white);
				border: 1px solid rgba(255, 255, 255, 0.15);
				box-shadow: 0 4px 15px rgba(193, 18, 31, 0.4);
			}

			.lang-btn:hover:not(.active) {
				color: var(--white);
				background: rgba(255, 255, 255, 0.05);
			}

			.top-tagline {
				font-family: var(--font-oriya);
				font-size: 1.4rem;
				font-weight: 500;
				color: var(--white);
				letter-spacing: 0.02em;
				margin-bottom: 0.5rem;
				text-shadow: 0 0 15px rgba(193, 18, 31, 0.6);
				animation: glowPulse 4s infinite ease-in-out;
				text-align: center;
			}

			@keyframes glowPulse {
				0%, 100% {
					text-shadow: 0 0 15px rgba(193, 18, 31, 0.4);
					opacity: 0.9;
				}
				50% {
					text-shadow: 0 0 25px rgba(193, 18, 31, 0.8), 0 0 5px var(--red);
					opacity: 1;
				}
			}

			.main-content {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				flex-grow: 1;
				width: 100%;
				margin: 2rem 0;
			}

			.logo {
				font-family: var(--font-teko);
				font-size: 8.5rem;
				line-height: 0.8;
				font-weight: 600;
				text-transform: lowercase;
				letter-spacing: -0.01em;
				margin: 0;
				color: var(--white);
				text-shadow: 0 4px 20px rgba(0, 0, 0, 0.8);
				user-select: none;
			}

			.logo span {
				color: var(--red);
				text-shadow: 0 0 20px rgba(193, 18, 31, 0.5);
			}

			.divider {
				width: 120px;
				height: 2px;
				background: linear-gradient(90deg, transparent, var(--red) 50%, transparent);
				margin: 1.5rem 0;
			}

			.subtitle {
				font-size: 1.25rem;
				font-weight: 300;
				color: var(--text-muted);
				max-width: 750px;
				margin: 0 0 3.5rem 0;
				line-height: 1.6;
				letter-spacing: 0.02em;
				text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
				text-align: center;
			}

			.status-label {
				font-size: 0.85rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.25em;
				color: var(--red);
				margin-bottom: 1.5rem;
				text-shadow: 0 0 10px rgba(193, 18, 31, 0.3);
			}

			.timer-container {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 1.5rem;
				margin-bottom: 2rem;
				width: 100%;
				max-width: 800px;
				user-select: none;
			}

			.timer-segment {
				display: flex;
				flex-direction: column;
				align-items: center;
				min-width: 160px;
				transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
				cursor: default;
			}

			.timer-segment:hover {
				transform: translateY(-5px) scale(1.03);
			}

			.timer-segment:hover .timer-number {
				color: var(--white);
				text-shadow: 0 0 25px rgba(193, 18, 31, 0.8), 0 5px 15px rgba(0, 0, 0, 0.6);
			}

			.timer-segment:hover .timer-label {
				color: var(--white);
			}

			.timer-number {
				font-family: var(--font-teko);
				font-size: 10.5rem;
				line-height: 0.8;
				font-weight: 500;
				color: var(--white);
				text-shadow: 0 5px 15px rgba(0, 0, 0, 0.5);
				transition: color 0.3s ease, text-shadow 0.3s ease;
				font-variant-numeric: tabular-nums;
				text-align: center;
				display: inline-block;
			}

			.timer-label {
				font-family: var(--font-sans), var(--font-oriya);
				font-size: 0.85rem;
				font-weight: 500;
				text-transform: uppercase;
				letter-spacing: 0.15em;
				color: var(--text-muted);
				margin-top: 0.75rem;
				transition: color 0.3s ease;
			}

			.timer-colon {
				font-family: var(--font-teko);
				font-size: 7.5rem;
				line-height: 0.8;
				color: var(--red);
				margin-top: -2rem;
				text-shadow: 0 0 15px rgba(193, 18, 31, 0.5);
			}

			.footer {
				text-align: center;
				margin-bottom: 1rem;
				width: 100%;
			}

			.footer-text {
				font-size: 0.95rem;
				color: var(--text-muted);
				letter-spacing: 0.05em;
				text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
			}

			.footer-divider {
				width: 40px;
				height: 1px;
				background: var(--text-dim);
				margin: 1rem auto 0 auto;
			}

			@media (max-width: 768px) {
				body {
					background-image:
						radial-gradient(circle at center, rgba(5, 5, 5, 0.55) 0%, rgba(5, 5, 5, 0.95) 100%),
						url('/bg-image.png');
					background-position: 80% center;
				}

				.container {
					padding: 2rem 1.5rem;
				}

				.header-top {
					justify-content: center;
					margin-bottom: 1.5rem;
				}

				.top-tagline {
					font-size: 1.15rem;
				}

				.logo {
					font-size: 5.5rem;
				}

				.subtitle {
					font-size: 1.05rem;
					margin-bottom: 2.5rem;
				}

				.timer-container {
					gap: 0.5rem;
				}

				.timer-segment {
					min-width: 110px;
				}

				.timer-number {
					font-size: 6.5rem;
				}

				.timer-colon {
					font-size: 5rem;
					margin-top: -1.25rem;
				}

				.timer-label {
					font-size: 0.7rem;
					letter-spacing: 0.1em;
				}

				.footer-text {
					font-size: 0.85rem;
				}
			}

			@media (max-width: 480px) {
				.logo {
					font-size: 4.2rem;
				}

				.timer-container {
					gap: 0.35rem;
				}

				.timer-segment {
					min-width: 80px;
				}

				.timer-number {
					font-size: 4.5rem;
				}

				.timer-colon {
					font-size: 3.5rem;
					margin-top: -1rem;
				}

				.timer-label {
					font-size: 0.6rem;
				}
			}
		</style>

		<script>
			const launchDate = new Date("2026-07-16T00:00:00+05:30").getTime();

			const translations = {
				en: {
					tagline: "Our Odisha, Our Identity.",
					subtitle: "Explore Odisha's glorious culture, rich history, authentic cuisine, breathtaking destinations, and countless untold stories - all in one place.",
					statusLabel: "LAUNCHING IN",
					daysLabel: "Days",
					hoursLabel: "Hours",
					minutesLabel: "Minutes",
					secondsLabel: "Seconds",
					footerText: "Stay tuned. A new way to experience Odisha's pride, culture, and beauty is coming soon."
				},
				od: {
					tagline: "ଆମ ଓଡ଼ିଶା, ଆମ ପରିଚୟ।",
					subtitle: "ଓଡ଼ିଶାର ଗୌରବମୟ ସଂସ୍କୃତି, ସମୃଦ୍ଧ ଇତିହାସ, ସ୍ୱାଦିଷ୍ଟ ବ୍ୟଞ୍ଜନ, ମନୋମୁଗ୍ଧକର ପର୍ଯ୍ୟଟନ ସ୍ଥଳୀ ଏବଂ ଅନେକ ଅଜଣା କାହାଣୀ - ସବୁକିଛି ଏକ ସ୍ଥାନରେ।",
					statusLabel: "ଶୁଭାରମ୍ଭ ପାଇଁ ଆଉ",
					daysLabel: "ଦିନ",
					hoursLabel: "ଘଣ୍ଟା",
					minutesLabel: "ମିନିଟ୍",
					secondsLabel: "ସେକେଣ୍ଡ୍",
					footerText: "ଓଡ଼ିଶାର ଗୌରବ, ସଂସ୍କୃତି ଓ ସୌନ୍ଦର୍ଯ୍ୟର ଏକ ନୂଆ ଅନୁଭବ ଶୀଘ୍ର ଆସୁଛି।"
				}
			};

			const odiaDigits = ['୦', '୧', '୨', '୩', '୪', '୫', '୬', '୭', '୮', '୯'];
			let currentLang: 'en' | 'od' = 'en';

			try {
				const savedLang = localStorage.getItem('pref-lang');
				if (savedLang === 'en' || savedLang === 'od') {
					currentLang = savedLang;
				}
			} catch (e) {
				console.warn('LocalStorage not accessible:', e);
			}

			function convertDigits(numStr: string, lang: 'en' | 'od') {
				if (lang !== 'od') return numStr;
				return numStr.replace(/[0-9]/g, (match) => odiaDigits[parseInt(match)]);
			}

			function updateLanguageDOM() {
				const langData = translations[currentLang];

				const taglineEl = document.getElementById("tagline");
				const subtitleEl = document.getElementById("subtitle");
				const statusEl = document.getElementById("status-label");
				const footerEl = document.getElementById("footer-text");

				if (taglineEl) taglineEl.innerText = langData.tagline;
				if (subtitleEl) subtitleEl.innerText = langData.subtitle;
				if (statusEl) statusEl.innerText = langData.statusLabel;
				if (footerEl) footerEl.innerText = langData.footerText;

				const daysLabelEl = document.getElementById("days-label");
				const hoursLabelEl = document.getElementById("hours-label");
				const minutesLabelEl = document.getElementById("minutes-label");
				const secondsLabelEl = document.getElementById("seconds-label");

				if (daysLabelEl) daysLabelEl.innerText = langData.daysLabel;
				if (hoursLabelEl) hoursLabelEl.innerText = langData.hoursLabel;
				if (minutesLabelEl) minutesLabelEl.innerText = langData.minutesLabel;
				if (secondsLabelEl) secondsLabelEl.innerText = langData.secondsLabel;

				document.documentElement.lang = currentLang;

				const btnOd = document.getElementById("btn-od");
				const btnEn = document.getElementById("btn-en");
				if (btnOd && btnEn) {
					if (currentLang === 'od') {
						btnOd.classList.add("active");
						btnEn.classList.remove("active");
					} else {
						btnEn.classList.add("active");
						btnOd.classList.remove("active");
					}
				}
			}

			function updateCountdown() {
				const now = new Date().getTime();
				const difference = launchDate - now;

				const daysElement = document.getElementById("days");
				const hoursElement = document.getElementById("hours");
				const minutesElement = document.getElementById("minutes");
				const secondsElement = document.getElementById("seconds");

				if (difference <= 0) {
					const zeroStr = convertDigits("00", currentLang);
					if (daysElement) daysElement.innerText = zeroStr;
					if (hoursElement) hoursElement.innerText = zeroStr;
					if (minutesElement) minutesElement.innerText = zeroStr;
					if (secondsElement) secondsElement.innerText = zeroStr;
					return;
				}

				const days = Math.floor(difference / (1000 * 60 * 60 * 24));
				const hours = Math.floor((difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
				const minutes = Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60));
				const seconds = Math.floor((difference % (1000 * 60)) / 1000);

				const daysStr = String(days).padStart(2, '0');
				const hoursStr = String(hours).padStart(2, '0');
				const minutesStr = String(minutes).padStart(2, '0');
				const secondsStr = String(seconds).padStart(2, '0');

				if (daysElement) daysElement.innerText = convertDigits(daysStr, currentLang);
				if (hoursElement) hoursElement.innerText = convertDigits(hoursStr, currentLang);
				if (minutesElement) minutesElement.innerText = convertDigits(minutesStr, currentLang);
				if (secondsElement) secondsElement.innerText = convertDigits(secondsStr, currentLang);
			}

			function initLangSwitcher() {
				const btnOd = document.getElementById("btn-od");
				const btnEn = document.getElementById("btn-en");

				if (btnOd) {
					btnOd.addEventListener('click', () => {
						if (currentLang !== 'od') {
							currentLang = 'od';
							try {
								localStorage.setItem('pref-lang', 'od');
							} catch (e) {}
							updateLanguageDOM();
							updateCountdown();
						}
					});
				}

				if (btnEn) {
					btnEn.addEventListener('click', () => {
						if (currentLang !== 'en') {
							currentLang = 'en';
							try {
								localStorage.setItem('pref-lang', 'en');
							} catch (e) {}
							updateLanguageDOM();
							updateCountdown();
						}
					});
				}
			}

			initLangSwitcher();
			updateLanguageDOM();
			updateCountdown();

			setInterval(updateCountdown, 1000);
		</script>
	</body>
</html>
